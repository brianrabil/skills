{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", ".output/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "//#lint": {},
    "//#lint:fix": {
      "cache": false
    },
    "//#fmt:check": {},
    "//#fmt": {
      "dependsOn": ["//#lint:fix"],
      "cache": false
    },
    "//#quality": {
      "dependsOn": ["//#lint", "//#fmt:check"]
    },
    "//#quality:fix": {
      "dependsOn": ["//#lint:fix", "//#fmt"]
    },
    "//#skills:sync": {
      "cache": false
    }
  }
}
